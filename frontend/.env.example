# fal.ai API key (get from https://fal.ai/dashboard)
FAL_KEY=your_fal_key_here

# URL to your finetuned LoRA weights (fal.ai CDN URL or any https URL)
LORA_URL=https://fal.run/files/...

# Default prompt pre-filled in the UI (optional)
DEFAULT_PROMPT=

# Local port for the web server (default: 8000)
PORT=8000

# ngrok auth token (get from https://dashboard.ngrok.com/get-started/your-authtoken)
# Required only if using start.py for automatic tunnel creation
NGROK_AUTHTOKEN=your_ngrok_authtoken_here
